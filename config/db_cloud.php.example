<?php
/**
 * Cloud Database Configuration Template
 * 
 * INSTRUCTIONS:
 * 1. Copy this file and rename it to db.php
 * 2. Replace the values below with your cloud database credentials
 * 3. Test the connection using test_cloud_connection.php
 */

// Cloud Database Configuration
define('DB_HOST', 'your-cloud-host.com');     // Your cloud MySQL host (e.g., mysql.example.com, 123.45.67.89)
define('DB_USER', 'your_username');            // Your cloud database username
define('DB_PASS', 'your_password');            // Your cloud database password
define('DB_NAME', 'pharmacy_db');              // Database name (keep as pharmacy_db)
define('DB_PORT', '3306');                     // MySQL port (usually 3306)

// Optional: SSL Configuration (recommended for cloud databases)
// Uncomment and configure if your cloud provider requires SSL
/*
define('DB_SSL_CA', '/path/to/ca-cert.pem');
define('DB_SSL_CERT', '/path/to/client-cert.pem');
define('DB_SSL_KEY', '/path/to/client-key.pem');
*/

// Create connection
if (defined('DB_PORT')) {
    $conn = mysqli_init();
    
    // Enable SSL if configured
    if (defined('DB_SSL_CA')) {
        mysqli_ssl_set($conn, DB_SSL_KEY, DB_SSL_CERT, DB_SSL_CA, NULL, NULL);
    }
    
    mysqli_real_connect($conn, DB_HOST, DB_USER, DB_PASS, DB_NAME, DB_PORT);
} else {
    $conn = mysqli_connect(DB_HOST, DB_USER, DB_PASS, DB_NAME);
}

// Check connection
if (!$conn) {
    die("Connection failed: " . mysqli_connect_error());
}

// Set charset to UTF-8
mysqli_set_charset($conn, "utf8mb4");

// Set timezone (optional)
mysqli_query($conn, "SET time_zone = '+00:00'");

// Start session if not already started
if (session_status() === PHP_SESSION_NONE) {
    session_start();
}

/**
 * COMMON CLOUD PROVIDERS EXAMPLES:
 * 
 * AWS RDS:
 * DB_HOST: your-instance.region.rds.amazonaws.com
 * DB_PORT: 3306
 * 
 * Google Cloud SQL:
 * DB_HOST: your-instance-ip or /cloudsql/project:region:instance
 * DB_PORT: 3306
 * 
 * Azure Database for MySQL:
 * DB_HOST: your-server.mysql.database.azure.com
 * DB_PORT: 3306
 * DB_USER: username@servername
 * 
 * DigitalOcean Managed Database:
 * DB_HOST: your-cluster.db.ondigitalocean.com
 * DB_PORT: 25060 (or custom port)
 * 
 * Heroku ClearDB:
 * Use the CLEARDB_DATABASE_URL environment variable
 * 
 * PlanetScale:
 * DB_HOST: your-database.connect.psdb.cloud
 * DB_PORT: 3306
 * Requires SSL
 */
?>
